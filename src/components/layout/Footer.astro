---
import Container from "@/components/ui/Container.astro";
import Input from "@/components/ui/Input.astro";
import Button from "@/components/ui/Button.astro";
---

<footer class="bg-[#3D3D3D] text-white">
    <Container>
        <div class="py-16 grid grid-cols-1 md:grid-cols-4 gap-12">
            <!-- Practice Info -->
            <div class="md:col-span-1">
                <div class="flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 bg-sage rounded-full"></div>
                    <h3 class="font-serif text-xl">Stephany Pesantez</h3>
                </div>
                <p class="text-sm text-gray-300 mb-6">
                    Fundamentada en el cuidado. Impulsada por la comprensión.
                </p>
                <div class="flex gap-4">
                    <a
                        href="#"
                        class="hover:text-sage transition"
                        aria-label="Facebook"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"
                            ></path></svg
                        >
                    </a>
                    <a
                        href="#"
                        class="hover:text-sage transition"
                        aria-label="Instagram"
                    >
                        <svg
                            class="w-5 h-5"
                            fill="currentColor"
                            viewBox="0 0 24 24"
                            ><path
                                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"
                            ></path></svg
                        >
                    </a>
                </div>
            </div>

            <!-- Practice Links -->
            <div>
                <h4 class="font-semibold mb-4">PRÁCTICA</h4>
                <nav class="flex flex-col gap-3 text-sm text-gray-300">
                    <a href="/about" class="hover:text-sage transition"
                        >Acerca</a
                    >
                    <a href="/services" class="hover:text-sage transition"
                        >Servicios</a
                    >
                    <a href="/resources" class="hover:text-sage transition"
                        >Recursos</a
                    >
                    <a href="/contact" class="hover:text-sage transition"
                        >Preguntas Frecuentes</a
                    >
                </nav>
            </div>

            <!-- Contact Links -->
            <div>
                <h4 class="font-semibold mb-4">CONTACTO</h4>
                <div class="flex flex-col gap-3 text-sm text-gray-300">
                    <a
                        href="mailto:hello@drthorne.com"
                        class="hover:text-sage transition"
                    >
                        hello@drthorne.com
                    </a>
                    <p>
                        123 Wellness Way, Suite 4<br />
                        San Francisco, CA 94110
                    </p>
                    <a href="/contact" class="hover:text-sage transition">
                        Agendar Consulta
                    </a>
                </div>
            </div>

            <!-- Newsletter -->
            <div>
                <h4 class="font-semibold mb-4">BOLETÍN</h4>
                <p class="text-sm text-gray-300 mb-4">
                    Perspectivas sobre salud mental, crecimiento y bienestar.
                </p>
                <form class="flex gap-2">
                    <Input
                        name="email"
                        type="email"
                        placeholder="Tu correo electrónico"
                        class="flex-1 bg-white/10 border-white/20 text-white placeholder:text-gray-400"
                    />
                    <Button type="submit" variant="primary" class="shrink-0">
                        <svg
                            class="w-4 h-4"
                            fill="none"
                            stroke="currentColor"
                            viewBox="0 0 24 24"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                        </svg>
                    </Button>
                </form>
            </div>
        </div>

        <!-- Copyright -->
        <div
            class="border-t border-white/10 py-6 text-center text-sm text-gray-400"
        >
            <p>
                © 2024 Stephany Pesantez, Psicóloga Clínica. Todos los derechos
                reservados.
            </p>
        </div>
    </Container>
</footer>
