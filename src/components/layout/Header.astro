                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 0 0-3.37-1.37V0h-3.4v14.74a3.3 3.3 0 1 1-3.3-3.3c.09 0 .18 0 .28.01v-3.41a6.68 6.68 0 1 0 6.42 6.67V8.52a8.21 8.21 0 0 0 3.37.74V5.86c0 .01 0 .01 0 0v.83z"></path></svg>
