---
import Container from "@/components/ui/Container.astro";
---

<header
    class="w-full border-b border-black/5 bg-nude/80 backdrop-blur-sm sticky top-0 z-50"
>
    <Container>
        <div class="flex h-20 items-center justify-between">
            <!-- Logo / Nombre -->
            <a
                href="/"
                class="flex items-center gap-2 font-title text-lg tracking-wide text-charcoal hover:opacity-80 transition"
            >
                <img
                    src="/images/logo_stephany.png"
                    alt="Logo Stephany Pesantez"
                    class="h-12 w-auto"
                />
                <span>Stephany Pesantez</span>
            </a>

            <!-- Desktop Navigation -->
            <nav class="hidden md:flex gap-8 text-sm font-medium">
                <a href="/" class="text-charcoal hover:text-sage transition">Inicio</a>
                <a href="/about" class="text-charcoal hover:text-sage transition">Acerca</a>
                <a href="/services" class="text-charcoal hover:text-sage transition">Servicios</a>
                <a href="/contact" class="text-charcoal hover:text-sage transition">Contacto</a>
            </nav>

            <!-- Desktop CTA -->
            <div class="hidden md:block">
                <a
                    href="https://wa.me/593992798792"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center justify-center font-medium px-4 py-2 text-sm bg-sage hover:bg-sage-dark text-white rounded-card shadow-soft hover:shadow-card hover:-translate-y-0.5 transition-all duration-200"
                >
                    Agendar Sesión
                </a>
            </div>

            <!-- Mobile Hamburger Button -->
            <button
                id="mobile-menu-btn"
                class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-[6px] p-1"
                class="md:hidden flex flex-col justify-center items-center w-10 h-10 gap-[6px] p-1 shrink-0 relative z-50 text-charcoal hover:bg-black/5 rounded-lg cursor-pointer transition-colors"
                aria-label="Abrir menú de navegación"
                aria-expanded="false"
            >
                <span class="hamburger-line block w-7 h-[3px] bg-charcoal rounded-full transition-all duration-300 origin-center"></span>
                <span class="hamburger-line block w-7 h-[3px] bg-charcoal rounded-full transition-all duration-300 origin-center"></span>
                <span class="hamburger-line block w-7 h-[3px] bg-charcoal rounded-full transition-all duration-300 origin-center"></span>
                <span class="hamburger-line block w-7 h-[3px] bg-current rounded-full transition-all duration-300 origin-center"></span>
                <span class="hamburger-line block w-7 h-[3px] bg-current rounded-full transition-all duration-300 origin-center"></span>
                <span class="hamburger-line block w-7 h-[3px] bg-current rounded-full transition-all duration-300 origin-center"></span>
            </button>
        </div>
    </Container>
</header>

<!-- Mobile Menu Overlay -->
<div id="mobile-menu-overlay" class="fixed inset-0 bg-charcoal/40 backdrop-blur-sm z-40 opacity-0 pointer-events-none transition-opacity duration-300"></div>

<!-- Mobile Menu Panel -->
<nav
    id="mobile-menu"
    class="fixed top-0 right-0 h-full w-72 bg-nude z-50 shadow-2xl translate-x-full transition-transform duration-300 ease-out flex flex-col"
>
    <!-- Close Button -->
    <div class="flex items-center justify-between p-6 border-b border-black/5">
        <span class="font-serif text-charcoal text-lg">Menú</span>
        <button id="mobile-menu-close" class="w-10 h-10 flex items-center justify-center rounded-lg hover:bg-charcoal/5 transition-colors" aria-label="Cerrar menú">
            <svg class="w-6 h-6 text-charcoal" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>

    <!-- Navigation Links -->
    <div class="flex flex-col flex-1 p-6 space-y-2">
        <a href="/" class="mobile-nav-link flex items-center gap-3 px-4 py-3 rounded-xl text-charcoal hover:bg-sage/10 hover:text-sage transition-all duration-200 font-medium">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" /></svg>
