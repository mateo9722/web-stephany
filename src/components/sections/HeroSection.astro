---
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
---

<section class="bg-nude py-12 lg:py-16">
    <Container>
        <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
            <!-- Left Content -->
            <div class="space-y-6">
                <p class="text-sm uppercase tracking-wider text-charcoal/60 reveal">
                    FUNDAMENTADA EN LA COMPASIÓN
                </p>
                <h1
                    class="text-5xl lg:text-6xl font-serif text-charcoal leading-tight reveal reveal-delay-1"
                >
                    Encuentra tu equilibrio en un mundo cambiante.
                </h1>
                <p class="text-lg text-charcoal/70 leading-relaxed reveal reveal-delay-2">
                    Un espacio seguro centrado en la calidez, claridad y
                    conexión humana. Navegamos juntos las complejidades de la
                    vida.
                </p>
                <div class="flex flex-col sm:flex-row gap-4 pt-4 reveal reveal-delay-3">
                    <Button href="https://wa.me/593992798792" target="_blank" rel="noopener noreferrer" variant="primary">
                        Comienza Tu Camino
                    </Button>
                    <Button href="/about" variant="outline">
                        Conoce Mi Enfoque
                    </Button>
                </div>
            </div>

            <!-- Right Content - Image with Card -->
            <div class="relative reveal reveal-right reveal-delay-2">
                <div class="relative rounded-2xl overflow-hidden shadow-2xl">
                    <img
                        src="/images/stephany_professional.png"
                        alt="Psicóloga Stephany Pesantez"
                        class="w-full h-auto object-cover"
                    />
                </div>
            </div>
        </div>
    </Container>
</section>
