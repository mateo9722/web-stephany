---
import Container from "@/components/ui/Container.astro";
import Card from "@/components/ui/Card.astro";
---

<section class="bg-nude py-20">
    <Container>
        <!-- Section Header -->
        <div class="mb-16">
            <h2 class="font-title text-3xl md:text-4xl text-charcoal mb-4">
                La Trayectoria Profesional
            </h2>
        </div>

        <!-- Journey Timeline -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-16">
            <!-- Left Column - Timeline -->
            <div class="space-y-8">
                <!-- Foundation & Education -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-2 h-2 bg-sage rounded-full mt-2"
                    >
                    </div>
                    <div>
                        <h3 class="font-semibold text-xl text-charcoal mb-2">
                            Formación y Educación
                        </h3>
                        <p class="text-charcoal/70">
                            Comencé mi camino con una maestría en Psicología
                            Clínica de una institución acreditada, enfocándome
                            en intervenciones basadas en evidencia y relaciones
                            terapéuticas.
                        </p>
                    </div>
                </div>

                <!-- Clinical Specialization -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-2 h-2 bg-sage rounded-full mt-2"
                    >
                    </div>
                    <div>
                        <h3 class="font-semibold text-xl text-charcoal mb-2">
                            Especialización Clínica
                        </h3>
                        <p class="text-charcoal/70">
                            Pasé años trabajando con poblaciones diversas en
                            entornos clínicos, especializándome en ansiedad,
                            dinámica de relaciones y crecimiento de identidad.
                        </p>
                    </div>
                </div>

                <!-- Ongoing Advocacy -->
                <div class="flex gap-4">
                    <div
                        class="flex-shrink-0 w-2 h-2 bg-sage rounded-full mt-2"
                    >
                    </div>
                    <div>
                        <h3 class="font-semibold text-xl text-charcoal mb-2">
                            Defensa Continua
                        </h3>
                        <p class="text-charcoal/70">
                            Continúo brindando orientación informada y empática,
                            fortaleciendo a los estudiantes a través del lente
                            de la psicología basada en evidencia.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Right Column - Core Pillars -->
            <div>
                <h3 class="font-title text-2xl text-charcoal mb-6">
                    Pilares Fundamentales
                </h3>
                <div class="space-y-4">
                    <Card variant="white" padding="md" shadow={true}>
                        <div class="flex items-start gap-4">
                            <div
                                class="flex-shrink-0 w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center"
                            >
                                <svg
                                    class="w-5 h-5 text-sage"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-charcoal mb-1">
                                    Seguridad Primero
                                </h4>
                                <p class="text-sm text-charcoal/70">
                                    Un entorno terapéutico seguro y confidencial
                                    es la base de nuestro trabajo.
                                </p>
                            </div>
                        </div>
                    </Card>

                    <Card variant="white" padding="md" shadow={true}>
                        <div class="flex items-start gap-4">
                            <div
                                class="flex-shrink-0 w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center"
                            >
                                <svg
                                    class="w-5 h-5 text-sage"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-charcoal mb-1">
                                    Basado en Evidencia
                                </h4>
                                <p class="text-sm text-charcoal/70">
                                    Utilizo prácticas respaldadas por la
                                    investigación para obtener resultados
                                    efectivos.
                                </p>
                            </div>
                        </div>
                    </Card>

                    <Card variant="white" padding="md" shadow={true}>
                        <div class="flex items-start gap-4">
                            <div
                                class="flex-shrink-0 w-10 h-10 rounded-full bg-sage/10 flex items-center justify-center"
                            >
                                <svg
                                    class="w-5 h-5 text-sage"
                                    fill="currentColor"
                                    viewBox="0 0 24 24"
                                >
                                    <path
                                        d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                    ></path>
                                </svg>
                            </div>
                            <div>
                                <h4 class="font-semibold text-charcoal mb-1">
                                    Centrado en el Ser Humano
                                </h4>
                                <p class="text-sm text-charcoal/70">
                                    Tu experiencia única guía nuestro trabajo
                                    terapéutico juntos.
                                </p>
                            </div>
                        </div>
                    </Card>
                </div>
            </div>
        </div>
    </Container>
</section>
