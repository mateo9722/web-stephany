---
interface Props {
    variant?: "white" | "rose" | "nude" | "transparent";
    padding?: "sm" | "md" | "lg";
    shadow?: boolean;
    class?: string;
}

const {
    variant = "white",
    padding = "md",
    shadow = true,
    class: className = "",
} = Astro.props;

const variantClasses = {
    white: "bg-white",
    rose: "bg-rose-light",
    nude: "bg-nude",
    transparent: "bg-transparent",
};

const paddingClasses = {
    sm: "p-4",
    md: "p-6",
    lg: "p-8",
};

const shadowClass = shadow ? "shadow-card" : "";

const classes = `rounded-card-lg ${variantClasses[variant]} ${paddingClasses[padding]} ${shadowClass} ${className}`;
---

<div class={classes}>
    <slot />
</div>
