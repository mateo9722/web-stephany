---
import "../styles/tailwind.css";

interface Props {
    title?: string;
    description?: string;
}

const {
    title = "Psicóloga clínica | Psicoterapia para adolescentes y adultos",
    description = "Acompañamiento psicológico con una mirada humana.",
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />
</head>

<body class="bg-stone-50 text-stone-700 antialiased">
<slot />
</body>
</html>