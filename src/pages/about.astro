---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Container from "@/components/ui/Container.astro";
import Button from "@/components/ui/Button.astro";
import ProfessionalExperience from "@/components/sections/ProfessionalExperience.astro";
---

<BaseLayout title="Sobre Mí - Stephany Pesantez">
  <!-- Hero / Intro Section -->
  <section class="bg-nude py-20 lg:py-24">
    <Container>
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <!-- Image -->
        <div class="order-2 lg:order-1 relative">
          <div
            class="relative rounded-2xl overflow-hidden shadow-xl aspect-[3/4] max-w-md mx-auto lg:mx-0"
          >
            <img
              src="/images/stephany_consultorio.jpg"
              alt="Stephany Pesantez en su consultorio"
              class="w-full h-full object-cover"
            />
          </div>
          <!-- Deco Element -->
          <div
            class="absolute -bottom-6 -right-6 w-24 h-24 bg-sage/20 rounded-full -z-10 hidden lg:block"
          >
          </div>
          <div
            class="absolute -top-6 -left-6 w-32 h-32 bg-rose/30 rounded-full -z-10 hidden lg:block"
          >
          </div>
        </div>

        <!-- Text Content -->
        <div class="order-1 lg:order-2 space-y-6">
          <p
            class="text-sm uppercase tracking-wider text-charcoal/60 font-medium"
          >
            PSICÓLOGA CLÍNICA
          </p>
          <h1
            class="text-4xl lg:text-5xl font-serif text-charcoal leading-tight"
          >
            Hola, soy Stephany.
          </h1>
          <div class="space-y-4 text-lg text-charcoal/80 leading-relaxed">
            <p>
              Soy <strong>Stephany Pesantez</strong>, Psicóloga Clínica graduada
              en la Pontificia Universidad Católica del Ecuador.
            </p>
            <p>
              Mi enfoque se basa en crear un espacio seguro y empático para el
              crecimiento personal. Además, cuento con un diplomado en <strong
                >neuropsicología</strong
              >, especializándome en trastornos del neurodesarrollo y
              neurodegenerativos.
            </p>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Professional Path / Experience Section -->
  <section class="bg-white py-20 lg:py-24">
    <Container>
      <div class="max-w-4xl mx-auto">
        <div class="text-center mb-14">
          <p
            class="text-sm uppercase tracking-wider text-sage font-medium mb-3 reveal"
          >
            TRAYECTORIA
          </p>
          <h2
            class="text-3xl lg:text-4xl font-serif text-charcoal mb-4 reveal reveal-delay-1"
          >
            Experiencia y Formación
          </h2>
          <div class="w-16 h-[2px] bg-sage mx-auto reveal reveal-delay-2"></div>
        </div>

        <div class="grid md:grid-cols-2 gap-12">
          <!-- Education Column -->
          <div class="space-y-8 reveal reveal-delay-1">
            <h3 class="text-xl font-serif text-sage flex items-center gap-3">
              <svg
                class="w-6 h-6 text-sage"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M4.26 10.147a60.436 60.436 0 00-.491 6.347A48.627 48.627 0 0112 20.904a48.627 48.627 0 018.232-4.41 60.46 60.46 0 00-.491-6.347m-15.482 0a50.57 50.57 0 00-2.658-.813A59.905 59.905 0 0112 3.493a59.902 59.902 0 0110.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.697 50.697 0 0112 13.489a50.702 50.702 0 017.74-3.342M6.75 15a.75.75 0 100-1.5.75.75 0 000 1.5zm0 0v-3.675A55.378 55.378 0 0112 8.443m-7.007 11.55A5.981 5.981 0 006.75 15.75v-1.5"
                ></path></svg
              >
              Formación Académica
            </h3>

            <div class="pl-4 border-l-2 border-rose space-y-6">
              <div class="relative">
                <div
                  class="absolute -left-[21px] top-1 w-3 h-3 rounded-full bg-rose"
                >
                </div>
                <h4 class="font-bold text-charcoal">Psicóloga Clínica</h4>
                <p class="text-charcoal/70">
                  Pontificia Universidad Católica del Ecuador
                </p>
              </div>

              <div class="relative">
                <div
                  class="absolute -left-[21px] top-1 w-3 h-3 rounded-full bg-rose"
                >
                </div>
                <h4 class="font-bold text-charcoal">
                  Diplomado en Neuropsicología
                </h4>
                <p class="text-charcoal/70">
                  Trastornos del neurodesarrollo y neurodegenerativos
                </p>
              </div>
            </div>

            <!-- Certifications -->
            <div class="pt-8 space-y-8">
              <h3 class="text-xl font-serif text-sage flex items-center gap-3">
                <svg
                  class="w-6 h-6 text-sage"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                  stroke-width="1.5"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"
                  ></path></svg
                >
                Certificaciones
              </h3>
              <div class="pl-4 border-l-2 border-sage space-y-6">
                <div class="relative">
                  <div
                    class="absolute -left-[21px] top-1 w-3 h-3 rounded-full bg-sage"
                  >
                  </div>
                  <h4 class="font-bold text-charcoal">
                    Asesoría en Lactancia Materna
                  </h4>
                  <p class="text-charcoal/70">
                    Acompañamiento emocional en la etapa perinatal
                  </p>
                  <h4 class="font-bold text-charcoal">
                    Especialización de psicoeducadores en salud mental
                  </h4>
                  <p class="text-charcoal/70">
                    Formación especializada para educar y acompañar en salud
                    mental.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Experience Column -->
          <div class="space-y-8 reveal reveal-delay-2">
            <h3 class="text-xl font-serif text-sage flex items-center gap-3">
              <svg
                class="w-6 h-6 text-sage"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
                stroke-width="1.5"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 14.5M14.25 3.104c.251.023.501.05.75.082M19.8 14.5l-2.147 2.146a2.25 2.25 0 01-2.244.555l-.625-.195a2.25 2.25 0 00-2.567.755l-3.254 4.065a1.5 1.5 0 01-2.326.092l-.624-.687a1.5 1.5 0 01-.085-1.918L9.75 14.5"
                ></path></svg
              >
              Experiencia Clínica
            </h3>

            <p class="text-charcoal/70">
              Cuento con amplia experiencia trabajando con diversos desafíos
              emocionales y etapas de la vida:
            </p>

            <ul class="grid gap-4">
              <li class="flex items-start gap-3 bg-nude/30 p-4 rounded-lg">
                <svg
                  class="w-6 h-6 text-sage shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-charcoal/80"
                  >Prevención del suicidio e intervención en crisis</span
                >
              </li>
              <li class="flex items-start gap-3 bg-nude/30 p-4 rounded-lg">
                <svg
                  class="w-6 h-6 text-sage shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-charcoal/80"
                  >Manejo de ansiedad, depresión y duelo</span
                >
              </li>
              <li class="flex items-start gap-3 bg-nude/30 p-4 rounded-lg">
                <svg
                  class="w-6 h-6 text-sage shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-charcoal/80"
                  >Evaluación y abordaje de niños y adolescentes</span
                >
              </li>
              <li class="flex items-start gap-3 bg-nude/30 p-4 rounded-lg">
                <svg
                  class="w-6 h-6 text-sage shrink-0"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span class="text-charcoal/80"
                  >Neuropsicología y desarrollo cognitivo</span
                >
              </li>
            </ul>
          </div>
        </div>
      </div>
    </Container>
  </section>

  <!-- Detailed Professional Experience -->
  <ProfessionalExperience />

  <!-- CTA Section -->
  <section class="bg-rose py-20 relative">
    <Container>
      <div
        class="bg-white/60 backdrop-blur-md border border-white/50 rounded-3xl p-8 md:p-14 shadow-soft max-w-4xl mx-auto text-center"
      >
        <h2 class="text-3xl md:text-4xl font-serif text-charcoal mb-4 reveal">
          ¿Lista para comenzar?
        </h2>
        <div class="w-16 h-[2px] bg-sage mx-auto mb-6 reveal reveal-delay-1">
        </div>
        <p
          class="text-center text-charcoal/80 max-w-2xl mx-auto mb-10 text-lg leading-relaxed reveal reveal-delay-2"
        >
          Si sientes que es el momento de buscar apoyo o mejorar tu bienestar
          emocional, estoy aquí para acompañarte en el proceso.
        </p>
        <div
          class="flex flex-col sm:flex-row gap-4 justify-center reveal reveal-delay-3"
        >
          <a
            href="https://wa.me/593992798792"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center gap-3 bg-[#25D366] hover:bg-[#1da851] text-white font-semibold px-8 py-4 rounded-xl shadow-lg hover:shadow-xl hover:-translate-y-0.5 transition-all duration-300 text-base no-underline"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.029 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
            Escríbeme por WhatsApp
          </a>
          <a
            href="/contact"
            class="inline-flex items-center justify-center font-semibold px-8 py-4 rounded-xl border-2 border-sage text-sage hover:bg-sage hover:text-white transition-all duration-300 text-base no-underline"
          >
            Ir a Contacto
          </a>
        </div>
      </div>
    </Container>
  </section>
</BaseLayout>
