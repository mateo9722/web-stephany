---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../Header.astro";
---

<BaseLayout
        title="Psicóloga clínica | Psicoterapia para adolescentes y adultos"
        description="Acompañamiento psicológico con una mirada humana. Atención online y presencial."
>
    <Header />

    <!-- HERO -->
    <section class="bg-stone-50">
        <div class="mx-auto max-w-6xl px-6 lg:px-8 min-h-[85vh] grid lg:grid-cols-2 items-center gap-20">

            <!-- TEXTO -->
            <div class="max-w-xl">
        <span class="uppercase tracking-[0.25em] text-xs text-stone-500 mb-8 block">
          Psicología clínica
        </span>

                <h1 class="font-title text-4xl lg:text-5xl leading-tight text-stone-900 mb-8">
                    Acompañamiento psicológico<br />
                    con una mirada humana
                </h1>

                <p class="text-lg text-stone-600">
                    Psicoterapia para adolescentes y adultos. Un espacio de escucha y cuidado,
                    pensado para acompañarte en tu proceso.
                </p>
            </div>

            <!-- IMAGEN -->
            <div class="flex justify-center lg:justify-end">
                <img
                        src="/psic.jpeg"
                        alt="Psicóloga clínica"
                        class="w-[400px] h-[560px] object-cover shadow-xl"
                        style="border-radius: 42% 58% 55% 45% / 45% 45% 55% 55%;"
                />
            </div>

        </div>
    </section>

</BaseLayout>